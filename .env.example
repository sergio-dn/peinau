# ── Database (Supabase PostgreSQL or local) ──
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# ── Redis (Upstash or local) ──
REDIS_URL=rediss://default:[YOUR-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379

# ── JWT ──
JWT_SECRET=your-secret-key-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# ── Encryption key for SII credentials (64-char hex) ──
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Slack (optional) ──
SLACK_WEBHOOK_URL=

# ── Server ──
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Frontend (apps/web .env) ──
# VITE_API_URL= (leave empty for local proxy, set to Render URL in production)
