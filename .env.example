# Database
DATABASE_URL=postgresql://wildlama:wildlama@localhost:5432/wildlama_invoices

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# SII Credentials (encrypted at rest)
SII_RUT=
SII_PASSWORD=

# Encryption key for sensitive data (SII passwords, etc.)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Slack (optional)
SLACK_WEBHOOK_URL=

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
